# Bunny CDN credentials
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Your storage zone name (found in the Bunny CDN dashboard)
BUNNYCDN_STORAGE_ZONE=my-storage-zone

# Storage zone password — also used as the API key
# Found under Storage Zone → FTP & HTTP API Information
BUNNYCDN_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Region prefix for the storage API endpoint
# Options: ny (New York), la (Los Angeles), sg (Singapore), syd (Sydney), de (Falkenstein)
# Default: ny
BUNNYCDN_REGION=ny
